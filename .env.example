# ============================================================
# 台南土地公 — 環境變數範本
# 複製此檔為 .env，填入真實 key，不要把 .env 提交到 git！
# ============================================================

# ── 後端 (backend/) ─────────────────────────────────────────
# Google AI Studio API Key（用於 Gemini / Google ADK）
# 申請：https://aistudio.google.com/apikey
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your-google-api-key-here

# ── 前端 (frontend/) ────────────────────────────────────────
# Mapbox GL JS Token（地圖用）
# 申請：https://account.mapbox.com/
VITE_MAPBOX_TOKEN=your-mapbox-token-here

# OpenWeatherMap API Key（問神明天氣用）
# 申請：https://openweathermap.org/api
VITE_WEATHER_KEY=your-openweathermap-key-here

# 後端連線（本地開發預設值，通常不用改）
VITE_BACKEND_HTTP=http://127.0.0.1:8080
VITE_BACKEND_WS=ws://127.0.0.1:8080
