# ── Backend (FastAPI gateway) ─────────────────────────────────────────────────
# Google AI Studio — used by Google ADK
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your-google-api-key-here

# Google Maps Platform — used for Street View images on itinerary cards
# Enable "Street View Static API" at console.cloud.google.com
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# SQLite wish store path (optional, defaults to data/warmdata.db)
# DEG_WARMDATA_DB=data/warmdata.db

# ── Frontend (Next.js) — set these in Netlify dashboard or apps/web/.env.local ──
# All pages degrade gracefully when the backend is unavailable.
# Replace <your-backend> with your deployed backend URL (Railway/Render/Fly.io).

# Explore flow WebSocket
NEXT_PUBLIC_GATEWAY_WS=wss://your-backend.railway.app/ws/explore/a2ui

# Community Ask flow WebSocket
NEXT_PUBLIC_GATEWAY_WS_COMMUNITY=wss://your-backend.railway.app/ws/ask/a2ui

# Council flow WebSocket
NEXT_PUBLIC_GATEWAY_WS_COUNCIL=wss://your-backend.railway.app/ws/council/a2ui

# Dashboard HTTP API (for wish heatmap data)
NEXT_PUBLIC_GATEWAY_HTTP=https://your-backend.railway.app

# Local development defaults (uncomment to use):
# NEXT_PUBLIC_GATEWAY_WS=ws://127.0.0.1:8080/ws/explore/a2ui
# NEXT_PUBLIC_GATEWAY_WS_COMMUNITY=ws://127.0.0.1:8080/ws/ask/a2ui
# NEXT_PUBLIC_GATEWAY_WS_COUNCIL=ws://127.0.0.1:8080/ws/council/a2ui
# NEXT_PUBLIC_GATEWAY_HTTP=http://127.0.0.1:8080
